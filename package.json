  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint-staged": "lint-staged",
    "prisma:migrate:dev": "cross-env NODE_ENV=development pnpm exec prisma migrate dev",
    "prisma:reset:dev": "cross-env NODE_ENV=development pnpm exec prisma migrate reset",
    "prisma:migrate:test": "cross-env NODE_ENV=test pnpm exec prisma migrate deploy",
    "prisma:reset:test": "cross-env NODE_ENV=test pnpm exec prisma migrate reset",
    "prisma:migrate:prod": "cross-env NODE_ENV=production pnpm exec prisma migrate deploy",
    "prisma:reset:prod": "cross-env NODE_ENV=production pnpm exec prisma migrate reset"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,html,css,scss,yml,yaml}": "prettier --write --ignore-path .prettierignore"
  },
  "private": true,
  "dependencies": {
